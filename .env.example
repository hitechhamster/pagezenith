# 本地开发用（复制成 .env）。生产在 Render 控制台配环境变量，且【绝不提交 .env】。
# BYO-key 模式下，用户 key 由前端按请求传入，服务器不必配 OpenRouter/SerpApi key。

# 关闭 mock，走真实 API
USE_MOCKS=false

# SERP 数据源：serpapi（推荐，免费额度）| dataforseo
SERP_PROVIDER=serpapi

# 模型（OpenRouter）
LLM_MODEL=google/gemini-3.1-flash-lite
WRITER_MODEL=
EMBEDDING_MODEL=openai/text-embedding-3-large

# 抓取：browser=Playwright 过反爬（服务器推荐）| httpx=快但易 403
FETCH_MODE=browser
# 本地用系统 Chrome 免下载（chrome/msedge）；容器内置空用自带 Chromium
BROWSER_CHANNEL=chrome

# 公开部署安全
MAX_CONCURRENT_RUNS=2
BLOCK_PRIVATE_URLS=true

# ——本地自测兜底 key（生产不要放这里，用户自带）——
# OPENROUTER_API_KEY=sk-or-...
# SERPAPI_KEY=...
